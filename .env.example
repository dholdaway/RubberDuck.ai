# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/voice_to_code?schema=public"

# OpenAI — used for transcription (Whisper) and prompt generation (GPT-4)
OPENAI_API_KEY="sk-..."

# Anthropic — used for optional Claude code generation step
ANTHROPIC_API_KEY="sk-ant-..."

# Storage — local for MVP, set to "s3" to use S3-compatible storage
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"

# Optional S3 config (for future use)
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_ENDPOINT=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
